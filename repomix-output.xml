            boxShadow: _isPressed && widget.enabled
                ? NeonDecoration.neonButtonGlow()
                : NeonDecoration.neonCardShadow(opacity: 0.20),
          ),
          child: Center(
            child: widget.isLoading
                ? SizedBox(
                    width: 24,
