            label: AppStrings.equipment,
            value: provider.selectedVideobeam?.name ?? '',
          ),
          const SizedBox(height: 8),
          SummaryRow(
            icon: Icons.description_outlined,
            label: 'Notas',
            value: provider.notes.isEmpty
                ? 'Sin notas adicionales'
                : provider.notes,
          ),
          const SizedBox(height: 8),
          SummaryRow(
            icon: Icons.calendar_today,
