              );
            }
            return Column(
              children: resProv.reservations
                  .take(3)
                  .map((r) => UpcomingReservationTile(reservation: r))
                  .toList(),
            );
          },
        ),
      ],
    );
  }
}

class _CalendarioTab extends StatelessWidget {
