    final startStr = provider.startTime?.format(context) ?? '';
    final endStr = provider.endTime?.format(context) ?? '';

    return NeonCard(
      glowOpacity: 0.15,
      padding: const EdgeInsets.all(20),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
