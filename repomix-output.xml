                          fontSize: 14,
                          color: Colors.grey[600],
                        ),
                        maxLines: 1,
                        overflow: TextOverflow.ellipsis,
                      ),
                    ],
                  ),
                ),
                _StatusBadge(status: request.status),
              ],
            ),
            const SizedBox(height: 20),

            // Info Box: Equipment
            Container(
              padding: const EdgeInsets.all(15),
              decoration: BoxDecoration(
                color: const Color(0xFFF8F9FA),
                borderRadius: BorderRadius.circular(16),
              ),
              child: Row(
                children: [
                  Expanded(
                    child: _DetailItem(
                      icon: Icons.videocam_rounded,
                      label: 'EQUIPO',
                      value: request.videobeamName,
                    ),
                  ),
                ],
              ),
            ),
            const SizedBox(height: 12),

            // Date and Time separated blocks
            Row(
              children: [
                Expanded(
                  child: _DateTimeBlock(
                    icon: Icons.calendar_today,
                    label: 'FECHA',
                    value: _formatDate(request),
                  ),
                ),
                const SizedBox(width: 12),
                Expanded(
                  child: _DateTimeBlock(
                    icon: Icons.access_time_filled,
                    label: 'HORA',
                    value: '${request.startTime} - ${request.endTime}',
                  ),
                ),
              ],
            ),

            const SizedBox(height: 20),

            // Purpose / Notes
            if (request.notes != null && request.notes!.isNotEmpty) ...[
              Text(
                'Propósito',
                style: GoogleFonts.inter(
                  fontSize: 14,
                  fontWeight: FontWeight.w600,
                  color: Colors.grey[500],
                ),
              ),
              const SizedBox(height: 8),
              Text(
                request.notes!,
                style: GoogleFonts.inter(
                  fontSize: 15,
                  color: const Color(0xFF2D2D2D),
                  height: 1.5,
                  fontWeight: FontWeight.w500,
                ),
              ),
              const SizedBox(height: 20),
            ],

            // Actions
            if (isPending)
              Row(
                children: [
                  Expanded(
                    child: _ActionButton(
                      text: 'Declinar',
                      onPressed: () => provider.rejectRequest(request.id),
                      isPrimary: false,
                    ),
                  ),
                  const SizedBox(width: 15),
                  Expanded(
                    child: _ActionButton(
                      text: 'Aprobar',
                      onPressed: () => provider.approveRequest(request.id),
                      isPrimary: true,
                    ),
                  ),
                ],
              )
            else if (isApproved)
              Row(
                children: [
                  Expanded(
                    child: _ActionButton(
                      text: 'Cancelar',
                      onPressed: () => _confirmCancel(context),
                      isPrimary: false,
                    ),
                  ),
                ],
              ),
          ],
        ),
      ),
    );
  }

  void _confirmCancel(BuildContext context) {
    showDialog(
      context: context,
      builder: (ctx) => AlertDialog(
        title: const Text(AppStrings.cancelConfirmTitle),
        content: const Text(AppStrings.cancelConfirmMessage),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(ctx),
            child: const Text(AppStrings.cancel),
          ),
          TextButton(
            onPressed: () {
              Navigator.pop(ctx);
              provider.cancelRequest(request.id);
            },
            child: const Text(
              AppStrings.confirm,
              style: TextStyle(color: Colors.red),
            ),
          ),
        ],
      ),
    );
  }

  String _formatDate(ReservationEntity req) {
    final now = DateTime.now();
    String day = '';
    if (req.date.year == now.year &&
        req.date.month == now.month &&
        req.date.day == now.day) {
      day = 'Hoy';
    } else if (req.date.year == now.year &&
        req.date.month == now.month &&
        req.date.day == now.day + 1) {
      day = 'Mañana';
    } else {
      day = DateFormat('dd MMM yyyy').format(req.date);
    }
    return day;
  }
}

